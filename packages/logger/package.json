{
  "name": "@focusbuddy/logger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "pnpm build:clean && pnpm build:esm",
    "build:clean": "rm -rf ./dist",
    "build:esm": "pnpm --dir ../.. exec tsc --project packages/logger/tsconfig.build.json",
    "dev": "pnpm --dir ../.. exec tsc --project packages/logger/tsconfig.build.json --watch",
    "lint": "pnpm --dir ../.. exec oxlint packages/logger/src packages/logger/test",
    "test": "pnpm build && node --test ./test/logger.test.mjs",
    "typecheck": "pnpm --dir ../.. exec tsc --project packages/logger/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@focusbuddy/config-typescript": "workspace:*",
    "@types/node": "^25.5.2"
  }
}
