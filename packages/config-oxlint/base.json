{
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["typescript", "import", "unicorn", "oxc"],
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    ".next/**",
    ".turbo/**",
    "packages/api-contract/generated/**",
    "**/generated/**",
    "**/__generated__/**"
  ]
}
