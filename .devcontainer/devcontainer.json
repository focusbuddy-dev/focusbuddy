{
  "name": "focusbuddy",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "runArgs": ["--name", "${localWorkspaceFolderBasename}-dev", "--env-file", ".devcontainer/.devcontainer.env"],
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/focusbuddy,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/focusbuddy",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "GIT_PAGER": "cat",
    "FOCUSBUDDY_WORKSPACE_MOUNT": "${localWorkspaceFolder}",
    // The base image (node:24-bookworm) only ships C / C.utf8 / POSIX locales.
    // Without this, glibc falls back to POSIX → wcwidth() reports CJK chars as
    // width 1, which breaks Claude Code's TUI redraw on `claude --resume`.
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8"
  },
  "remoteEnv": {
    "http_proxy": "http://127.0.0.1:8888",
    "https_proxy": "http://127.0.0.1:8888",
    "HTTP_PROXY": "http://127.0.0.1:8888",
    "HTTPS_PROXY": "http://127.0.0.1:8888",
    "no_proxy": "localhost,127.0.0.1",
    "NO_PROXY": "localhost,127.0.0.1"
  },
  // The third mount intentionally uses a host path for both `source` and `target`.
  // When VS Code opens a worktree directly (`<repo>/.worktrees/<N>/`), the
  // worktree's `.git` is a pointer file whose body looks like:
  //   gitdir: /Users/<you>/workspace/focusbuddy/.git/worktrees/<N>
  // That host absolute path is baked into the file by `git worktree add` and
  // git inside the container reads it verbatim. Mounting the main repo's
  // `.git` at the same host path makes the pointer resolve. Picking a
  // conventional container target (e.g. `/workspaces/.git`) would not work
  // because git would still try to follow the host path written in `.git` and
  // find nothing there.
  "mounts": [
    "source=focusbuddy-claude-auth,target=/home/node/.claude,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer/allowlist.txt,target=/etc/tinyproxy/allowlist.txt,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/../../.git,target=${localWorkspaceFolder}/../../.git,type=bind,consistency=cached"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/start-proxy.sh",
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "settings": {
        "js/ts.tsdk.path": "node_modules/typescript/lib",
        "editor.formatOnSave": true
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma",
        "orta.vscode-jest",
        "stylelint.vscode-stylelint"
      ]
    }
  }
}
