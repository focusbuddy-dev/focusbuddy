{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/request-guard.mjs user-prompt",
        "timeout": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/request-guard.mjs pre-tool",
        "timeout": 15
      }
    ]
  }
}
