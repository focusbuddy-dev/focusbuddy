{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["generate", "^generate", "^build"],
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "generate": {
      "dependsOn": ["^generate"],
      "outputs": ["generated/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["generate", "^generate", "^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["generate", "^generate", "^build"],
      "outputs": []
    }
  }
}
